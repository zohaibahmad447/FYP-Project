# =============================================================================
# Quick Care Connect — environment template (copy to .env and fill values)
# NEVER commit .env to git
# =============================================================================

# --- Core ---
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
# DATABASE_URL=sqlite:///quickcare_dev.db

# Production example (Linux server):
# FLASK_ENV=production
# DATABASE_URL=sqlite:////var/www/quickcare/instance/quickcare.db

# --- Agora video calls (RTC) ---
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# --- Agora Cloud Recording + DigitalOcean Spaces ---
AGORA_ENABLE_RECORDING=false
AGORA_API_BASE=https://api.sd-rtn.com/v1/apps
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
AGORA_RECORDING_STORAGE_VENDOR=11
AGORA_RECORDING_STORAGE_REGION=0
AGORA_RECORDING_STORAGE_BUCKET=
AGORA_RECORDING_STORAGE_ACCESS_KEY=
AGORA_RECORDING_STORAGE_SECRET_KEY=
AGORA_RECORDING_STORAGE_ENDPOINT=https://YOUR_REGION.digitaloceanspaces.com
AGORA_RECORDING_FILE_PREFIX=recordings

# --- DigitalOcean Spaces (admin presigned playback) ---
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
DO_SPACES_PRESIGN_EXPIRES=3600

# --- Safepay payments ---
SAFEPAY_API_KEY=
SAFEPAY_SECRET_KEY=
SAFEPAY_BASE_URL=https://sandbox.api.getsafepay.com
SAFEPAY_CHECKOUT_URL=https://sandbox.api.getsafepay.com
SAFEPAY_ENVIRONMENT=sandbox

# --- AI chatbot (Q&A) ---
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_HTTP_REFERER=http://127.0.0.1:5000
OPENROUTER_APP_TITLE=Quick Care AI

# --- Maps (doctor practice location on profile pages) ---
# 1) Sign up free at https://www.geoapify.com/ → My Projects → create API key
# 2) Paste key below. Tiles use OpenFreeMap (no key). Geocoding uses Geoapify.
GEOAPIFY_API_KEY=
# Optional: liberty | bright | positron — default liberty
# OPENFREEMAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# --- Email — Namecheap Private Email (quickcares.me) ---
# 1) Namecheap → Private Email → Create mailbox (e.g. noreply@quickcares.me)
# 2) Advanced DNS: MX mx1/mx2.privateemail.com, SPF, DKIM (from Private Email panel)
# 3) Fill MAIL_USERNAME + MAIL_PASSWORD below, set ENABLE_EMAILS=true
ENABLE_EMAILS=false
MAIL_SERVER=mail.privateemail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=noreply@quickcares.me
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER_NAME=Quick Care Connect
MAIL_DEFAULT_SENDER_EMAIL=noreply@quickcares.me

# --- Admin reset script (scripts/reset_admin_login.py) ---
ADMIN_EMAIL=admin@quickcare.pk
ADMIN_PASSWORD=

# --- Business rules (defaults OK) ---
PLATFORM_COMMISSION_PERCENT=20
MIN_PAYOUT_PKR=1000
